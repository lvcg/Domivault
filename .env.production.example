NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional OCR language for Tesseract.js. Defaults to eng.
TESSERACT_LANG=eng

# Future production integrations.
NEXT_PUBLIC_APP_URL=https://your-domain.com
SENTRY_DSN=

# RevenueCat Purchases JS. Use the production public web SDK key from RevenueCat.
NEXT_PUBLIC_REVENUECAT_API_KEY=
NEXT_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium_access
NEXT_PUBLIC_REVENUECAT_MONTHLY_URL=
NEXT_PUBLIC_REVENUECAT_YEARLY_URL=
NEXT_PUBLIC_REVENUECAT_LIFETIME_URL=

REVENUECAT_WEBHOOK_AUTH_TOKEN=
REVENUECAT_WEBHOOK_SIGNING_SECRET=

# Web Push notifications. Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@domivault.app
